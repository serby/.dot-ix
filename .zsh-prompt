# Based on skwp

# Midway cookie expiry, refreshed at most once per minute.
# Sets _prompt_serby_midway to "MW-Exp HH:MM" (or empty if expired/missing).
function prompt_serby_midway_refresh {
  local cookie="$HOME/.midway/cookie"
  [[ -r "$cookie" ]] || { _prompt_serby_midway=""; return }
  local now=$(date +%s)
  (( now - ${_prompt_serby_midway_checked:-0} < 60 )) && return
  _prompt_serby_midway_checked=$now
  local exp
  exp=$(awk -F'\t' '$1=="#HttpOnly_midway-auth.amazon.com" && $6=="session" {print $5; exit}' "$cookie")
  if [[ -z "$exp" || "$exp" -le "$now" ]]; then
    _prompt_serby_midway=""
  else
    _prompt_serby_midway="MW-Exp $(date -r "$exp" +%H:%M)"
  fi
}

function prompt_serby_precmd {
  # Get Git repository information.
  if (( $+functions[git-info] )); then
    git-info
  fi
  prompt_serby_midway_refresh
}

function prompt_serby_setup {
  setopt LOCAL_OPTIONS
  unsetopt XTRACE KSH_ARRAYS
  prompt_opts=(cr percent subst)

  # Load required functions.
  autoload -Uz add-zsh-hook

  # Add hook to set up prompt parameters before each command.
  add-zsh-hook precmd prompt_serby_precmd

  # Use extended color pallete if available.
  if [[ $TERM = *256color* || $TERM = *rxvt* ]]; then
    _prompt_serby_colors=(
      "%F{63}"  # light blue
      "%F{166}" # Orange
      "%F{135}" # Purple
      "%F{161}" # Hotpink
      "%F{245}" # grey
    )
  else
    _prompt_serby_colors=(
      "%F{cyan}"
      "%F{yellow}"
      "%F{magenta}"
      "%F{red}"
      "%F{green}"
    )
  fi

  # Set git-info parameters.
  zstyle ':prezto:module:git:info' verbose 'yes'
  zstyle ':prezto:module:git:info:branch' format "${_prompt_serby_colors[4]}%b%f"
  zstyle ':prezto:module:git:info:added' format "${_prompt_serby_colors[5]}a%f"
  zstyle ':prezto:module:git:info:deleted' format "${_prompt_serby_colors[2]}d%f"
  zstyle ':prezto:module:git:info:modified' format "${_prompt_serby_colors[1]}m%f"
  zstyle ':prezto:module:git:info:untracked' format "${_prompt_serby_colors[3]}u%f"
  zstyle ':prezto:module:git:info:keys' format 'prompt' '%b %d%a%m%u '

  # Define prompts. The MW-Exp chip and git_info are kept single-quoted so they re-expand
  # on every prompt render (PROMPT has prompt_subst enabled via prompt_opts).
  if [ "$(uname -s)" = "Darwin" ]; then
    PROMPT="${_prompt_serby_colors[5]}%2d%f "'${_prompt_serby_midway:+%B%F{226}${_prompt_serby_midway}%f%b }${git_info:+${(e)git_info[prompt]}}'
  else
    PROMPT="${_prompt_serby_colors[3]}%n%f@${_prompt_serby_colors[2]}%m%f ${_prompt_serby_colors[5]}%2d%f "'${_prompt_serby_midway:+%B%F{226}${_prompt_serby_midway}%f%b }${git_info:+${(e)git_info[prompt]}}'
  fi
}

prompt_serby_setup "$@"
